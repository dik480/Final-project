<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Not Found | Pawtner</title>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; color: #1e293b; text-align: center; padding: 2rem; }
        .container { max-width: 400px; margin: 0 auto; background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
        h1 { color: #0f172a; font-size: 1.5rem; margin-bottom: 1rem; }
        p { color: #64748b; line-height: 1.5; margin-bottom: 2rem; }
        .icon { font-size: 3rem; margin-bottom: 1rem; color: #94a3b8; }
    </style>
</head>
<body>
    <div class="container">
        <div class="icon">❓</div>
        <h1>404 Not Found</h1>
        <p><%= locals.message ? message : "The requested page could not be found." %></p>
    </div>
</body>
</html>
